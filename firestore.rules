rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.userId;
    }
    function uidUnchanged() {
      return !('userId' in request.resource.data) || request.resource.data.userId == request.auth.uid;
    }
    function uidNotModified() {
      return !('userId' in request.resource.data) || request.resource.data.userId == resource.data.userId;
    }
    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }
    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }
    function validStringLength(field, minLen, maxLen) {
      return request.resource.data[field] is string &&
        request.resource.data[field].size() >= minLen &&
        request.resource.data[field].size() <= maxLen;
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    function isValidRejection() {
      return hasOnlyAllowedFields(['text', 'createdAt', 'userId']) &&
             validStringLength('text', 1, 1000) &&
             request.resource.data.createdAt is timestamp &&
             request.resource.data.userId == request.auth.uid;
    }

    function isValidSuccess() {
      return hasOnlyAllowedFields(['text', 'createdAt', 'userId']) &&
             validStringLength('text', 1, 1000) &&
             request.resource.data.createdAt is timestamp &&
             request.resource.data.userId == request.auth.uid;
    }

    function isValidUserStat() {
      return hasOnlyAllowedFields(['rejectionCount', 'isShattered', 'userId']) &&
             request.resource.data.rejectionCount is number &&
             request.resource.data.rejectionCount >= 0 &&
             request.resource.data.isShattered is bool &&
             request.resource.data.userId == request.auth.uid;
    }

    // ===============================================================
    // Rules
    // ===============================================================
    match /rejections/{rejectionId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && isValidRejection() && uidUnchanged();
      allow update: if isAuthenticated() && isDocOwner() && isValidRejection() && uidNotModified();
      allow delete: if isAuthenticated() && isDocOwner();
    }

    match /successes/{successId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && isValidSuccess() && uidUnchanged();
      allow update: if isAuthenticated() && isDocOwner() && isValidSuccess() && uidNotModified();
      allow delete: if isAuthenticated() && isDocOwner();
    }

    match /userStats/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUserStat() && uidUnchanged();
      allow update: if isOwner(userId) && isValidUserStat() && uidNotModified();
    }
  }
}
